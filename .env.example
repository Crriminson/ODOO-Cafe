# Server Configuration
PORT=5000
NODE_ENV=development

# Database — fill in your local values
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=odoocafe

# Or use a single connection string (takes priority over individual fields above)
# DATABASE_URL=postgres://postgres:your_password_here@localhost:5432/odoocafe

# Security — change this to a long random string in production
JWT_SECRET=change_me_to_something_long_and_random
JWT_EXPIRES_IN=1d

# Client origin for CORS
CLIENT_ORIGIN=http://localhost:5173
