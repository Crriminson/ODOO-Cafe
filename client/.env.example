# Client environment variables
# Copy to .env.local and fill in values — never commit .env.local

# Base URL for the Express API (no trailing slash)
VITE_API_URL=http://localhost:5000/api/v1

# Base URL for Socket.IO connection (no path)
VITE_SOCKET_URL=http://localhost:5000

# ── Offline / demo mock data ─────────────────────────────────────────────
# Set to "true" ONLY for local offline development or demo mode.
# When enabled, real backend 5xx errors and network failures fall back to
# hardcoded mock responses instead of surfacing an error to the user.
# NEVER set this in production — it will mask real failures silently.
VITE_ENABLE_MOCKS=false
