# Copy this file to .env and fill in your values before running the server.

# PostgreSQL connection string — adjust user, password, and DB name for your local setup
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/traveloop

# JWT secrets — use long random strings in production (e.g. openssl rand -hex 64)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Token expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=5000

# Frontend origin (for CORS)
CLIENT_URL=http://localhost:5173

# Environment
NODE_ENV=development
